# AgentTheSpire Web 端 Docker 部署变量
# 复制为 .env.web 后再编辑

# 项目名 / 容器名
ATS_PROJECT_NAME=agentthespire-web
ATS_WEB_CONTAINER=ats-web
ATS_FRONTEND_CONTAINER=ats-frontend
ATS_POSTGRES_CONTAINER=ats-postgres

# 镜像 tag
ATS_WEB_IMAGE=agentthespire/web:local
ATS_FRONTEND_IMAGE=agentthespire/frontend:local

# 监听端口
ATS_WEB_PORT=7870
ATS_FRONTEND_PORT=8080
ATS_POSTGRES_HOST_PORT=55432

# 基础镜像
ATS_PYTHON_BASE_IMAGE=python:3.11-slim
ATS_NODE_BASE_IMAGE=node:20-alpine
ATS_NGINX_BASE_IMAGE=nginx:1.27-alpine
ATS_POSTGRES_IMAGE=postgres:16-alpine

# Postgres 凭据；生产环境务必改密码
ATS_POSTGRES_DB=agentthespire
ATS_POSTGRES_USER=agentthespire
ATS_POSTGRES_PASSWORD=agentthespire

# 会话与凭据加密密钥（必填，任意 32+ 字节随机串）
SPIREFORGE_AUTH_SESSION_SECRET=
SPIREFORGE_SERVER_CREDENTIAL_SECRET=

# Workstation 控制 token（web 调度桌面工作站时使用，可空）
ATS_WORKSTATION_CONTROL_TOKEN=

# 前端运行时 API 基址；默认指向同机 web。
# 跨机部署时显式填写，例如 https://api.example.com
ATS_FRONTEND_WEB_BASE_URL=
ATS_FRONTEND_WEB_WS_BASE_URL=
ATS_FRONTEND_WORKSTATION_BASE_URL=
ATS_FRONTEND_WORKSTATION_WS_BASE_URL=
