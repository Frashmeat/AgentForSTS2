# AgentTheSpire 桌面端工作站 Docker 部署变量
# 复制为 .env.workstation 后再编辑

# 项目名 / 容器名
ATS_PROJECT_NAME=agentthespire-workstation
ATS_WORKSTATION_CONTAINER=ats-workstation
ATS_WORKSTATION_IMAGE=agentthespire/workstation:local

# 监听端口
ATS_WORKSTATION_PORT=7860

# 基础镜像（可改为内网镜像源）
ATS_PYTHON_BASE_IMAGE=python:3.11-slim
ATS_NODE_BASE_IMAGE=node:20-alpine

# 会话与凭据加密密钥（任意 32+ 字节随机串；本地玩可空）
SPIREFORGE_AUTH_SESSION_SECRET=
SPIREFORGE_SERVER_CREDENTIAL_SECRET=

# Workstation 控制 token（web 端调度时校验；本地单机可空）
ATS_WORKSTATION_CONTROL_TOKEN=

# 三类 API 密钥；留空则从 runtime/workstation.config.json 读
SPIREFORGE_LLM_KEY=
SPIREFORGE_IMG_KEY=
SPIREFORGE_IMG_SECRET=
